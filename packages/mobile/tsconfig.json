{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "jsx": "react-jsx",
    "lib": ["ES2022"],
    "types": ["react"],
    "paths": {
      "@history-gauntlet/shared": ["../../shared/src/index.ts"],
      "@history-gauntlet/shared/*": ["../../shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
