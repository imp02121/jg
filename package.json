{
  "name": "history-gauntlet",
  "version": "0.0.1",
  "private": true,
  "description": "The History Gauntlet - Daily history trivia challenges",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @history-gauntlet/shared --filter @history-gauntlet/api --filter @history-gauntlet/mobile --filter @history-gauntlet/dashboard typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome"
    ]
  }
}
