{
  "name": "@history-gauntlet/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared types, constants, and validators for The History Gauntlet",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*",
      "types": "./src/*"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsc --noEmit --watch",
    "lint": "biome check src/",
    "test": "echo \"No tests yet\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
